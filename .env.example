ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Exchange ──────────────────────────────────────────────────────────────
WEEX_API_KEY=your_weex_api_key
WEEX_SECRET=your_weex_secret
WEEX_PASSPHRASE=your_weex_passphrase

# ── Trading mode ──────────────────────────────────────────────────────────
PAPER_TRADING=true          # set false ONLY when ready for live
AUTO_TRADE=false            # set true for fully automatic execution

# ── Starting balance fallback ─────────────────────────────────────────────
# Live balance is always fetched from Weex on startup and every 30s.
# ACCOUNT_USDT is only used as:
#   1. The paper-mode simulation starting balance when the real API is unreachable
#   2. The paper_balance floor when paper mode is first initialised
# For a $100 real wallet set this to 100 so paper sizing matches reality.
ACCOUNT_USDT=100

# ── Risk settings (calibrated for a $100 account) ─────────────────────────
RISK_PCT=2                  # % of live balance risked per trade  → $2 risk on $100
MAX_TRADE_USDT=20           # hard cap on single-trade notional (USDT)
MIN_CONFIDENCE=75           # minimum AI confidence to execute
DAILY_LOSS_LIMIT_USDT=5     # stop trading today if daily loss exceeds this ($5 = 5% of $100)
MAX_CONCURRENT_TRADES=1     # max open positions at once (1 is safest on small accounts)

# ── Scanner settings ──────────────────────────────────────────────────────
TOP_N_COINS=20              # how many top-volume coins to scan each cycle
SCAN_INTERVAL_SECONDS=300   # seconds between full scan cycles (300 = 5 min)
MAX_HOURS_IN_TRADE=8        # close any trade still open after this many hours (time-stop)
BATCH_SIZE=5                # max candidates forwarded to Claude per scan
PRE_SCORE_THRESHOLD=55      # min pre-score (0–100) to qualify for Claude call

# ── News blackout ─────────────────────────────────────────────────────────
NEWS_BLACKOUT_MIN=30        # pause trading ±N minutes around high-impact events

# ── Telegram notifications ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Journal DB (SQLite) ───────────────────────────────────────────────────
JOURNAL_DB=trades.db
