ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Exchange ──────────────────────────────────────────────────────────────
WEEX_API_KEY=your_weex_api_key
WEEX_SECRET=your_weex_secret
WEEX_PASSPHRASE=your_weex_passphrase

# ── Trading mode ──────────────────────────────────────────────────────────
PAPER_TRADING=true          # set false ONLY when ready for live
AUTO_TRADE=false            # set true for fully automatic execution
ACCOUNT_USDT=500            # your starting balance for sizing

# ── Risk settings ─────────────────────────────────────────────────────────
MAX_TRADE_USDT=75           # max single trade notional (USDT)
RISK_PCT=1.0                # % of account risked per trade
MIN_CONFIDENCE=72           # minimum AI confidence to execute
DAILY_LOSS_LIMIT_USDT=50    # stop trading for the day if exceeded
MAX_CONCURRENT_TRADES=2     # max open positions at once

# ── Scanner settings ──────────────────────────────────────────────────────
TOP_N_COINS=20              # how many top-volume coins to scan each cycle
SCAN_INTERVAL_SECONDS=300   # seconds between full scan cycles (300 = 5 min)

# ── News blackout ─────────────────────────────────────────────────────────
NEWS_BLACKOUT_MIN=30        # pause trading ±N minutes around high-impact events

# ── Telegram notifications (get these from @BotFather and @userinfobot) ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── News sentiment ────────────────────────────────────────────────────────
# Free RSS (CoinDesk + CoinTelegraph + Decrypt) is used automatically — no key needed.
# CRYPTOPANIC_TOKEN is no longer required.

# ── Journal DB path (SQLite) ──────────────────────────────────────────────
JOURNAL_DB=trades.db
